<script>
  // DOM elements
  const dropArea = document.getElementById('dropArea');
  const fileInput = document.getElementById('fileInput');
  const fileListDiv = document.getElementById('fileList');
  const mergeBtn = document.getElementById('mergeBtn');
  const downloadBtn = document.getElementById('downloadBtn');
  const progressMsg = document.getElementById('progressMsg');

  let selectedFiles = [];   // store File objects

  // Open file dialog on click
  dropArea.addEventListener('click', () => fileInput.click());
  // Drag & drop
  dropArea.addEventListener('dragover', (e) => { e.preventDefault(); dropArea.style.background = '#fef9c3'; });
  dropArea.addEventListener('dragleave', () => { dropArea.style.background = '#fefce8'; });
  dropArea.addEventListener('drop', (e) => {
    e.preventDefault();
    dropArea.style.background = '#fefce8';
    const files = Array.from(e.dataTransfer.files).filter(f => f.type === 'application/pdf');
    if (files.length) addFiles(files);
    else alert('Please drop PDF files only.');
  });
  fileInput.addEventListener('change', (e) => {
    if (e.target.files.length) addFiles(Array.from(e.target.files));
  });

  function addFiles(newFiles) {
    selectedFiles.push(...newFiles);
    renderFileList();
  }

  function removeFile(index) {
    selectedFiles.splice(index, 1);
    renderFileList();
  }

  function renderFileList() {
    if (!selectedFiles.length) {
      fileListDiv.innerHTML = '<p>No files selected.</p>';
      downloadBtn.disabled = true;
      return;
    }
    let html = '';
    selectedFiles.forEach((file, idx) => {
      html += `<div class="file-item">
        <span>${file.name} (${(file.size/1024).toFixed(1)} KB)</span>
        <button class="remove-btn" data-index="${idx}" style="background:none; border:none; color:#dc2626; cursor:pointer;"><i class="fas fa-trash-alt"></i></button>
      </div>`;
    });
    fileListDiv.innerHTML = html;
    // attach remove events
    document.querySelectorAll('.remove-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const idx = parseInt(btn.dataset.index);
        removeFile(idx);
      });
    });
    downloadBtn.disabled = true;
  }

  async function mergePDFs(files) {
    const { PDFDocument } = PDFLib;
    const mergedPdf = await PDFDocument.create();
    for (let file of files) {
      const arrayBuffer = await file.arrayBuffer();
      const pdf = await PDFDocument.load(arrayBuffer);
      const pages = await mergedPdf.copyPages(pdf, pdf.getPageIndices());
      pages.forEach(page => mergedPdf.addPage(page));
    }
    const pdfBytes = await mergedPdf.save();
    return pdfBytes;
  }

  mergeBtn.addEventListener('click', async () => {
    if (selectedFiles.length < 2) {
      alert('Please select at least two PDF files to merge.');
      return;
    }
    progressMsg.style.display = 'block';
    mergeBtn.disabled = true;
    try {
      const pdfBytes = await mergePDFs(selectedFiles);
      // store the merged blob for download
      window.mergedBlob = new Blob([pdfBytes], { type: 'application/pdf' });
      downloadBtn.disabled = false;
      progressMsg.innerHTML = 'Merge completed! Click download.';
    } catch (err) {
      console.error(err);
      progressMsg.innerHTML = 'Error merging PDFs. Check file formats (must be valid PDF).';
    } finally {
      mergeBtn.disabled = false;
      setTimeout(() => { progressMsg.style.display = 'none'; }, 2000);
    }
  });

  downloadBtn.addEventListener('click', () => {
    if (window.mergedBlob) {
      saveAs(window.mergedBlob, 'merged_output.pdf');
    } else {
      alert('No merged PDF ready. Please merge first.');
    }
  });

  // FAQ toggle
  document.querySelectorAll('.faq-question').forEach(q => {
    q.addEventListener('click', () => {
      const answer = q.nextElementSibling;
      answer.style.display = answer.style.display === 'block' ? 'none' : 'block';
      q.querySelector('i').classList.toggle('fa-plus');
      q.querySelector('i').classList.toggle('fa-minus');
    });
  });

  // FAQ Schema JSON-LD
  const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {"@type":"Question","name":"Is this Merge PDF tool really free?","acceptedAnswer":{"@type":"Answer","text":"Yes, 100% free – no hidden payments, no signup required."}},
      {"@type":"Question","name":"Is it safe to merge PDFs online using this tool?","acceptedAnswer":{"@type":"Answer","text":"All merging happens inside your browser; your files never leave your device."}},
      {"@type":"Question","name":"Can I merge unlimited PDF files?","acceptedAnswer":{"@type":"Answer","text":"Yes, you can merge hundreds of PDFs – but keep in mind browser memory limits for huge files."}},
      {"@type":"Question","name":"Does merging reduce PDF quality?","acceptedAnswer":{"@type":"Answer","text":"No, the merger preserves original quality, fonts, and images without compression."}},
      {"@type":"Question","name":"Can I rearrange pages before merging?","acceptedAnswer":{"@type":"Answer","text":"Currently files are merged in the order you upload. For advanced page reordering, try our 'Organize PDF' tool."}},
      {"@type":"Question","name":"What happens to my files after merging?","acceptedAnswer":{"@type":"Answer","text":"Since no upload occurs, nothing is stored – your files are processed locally and stay private."}}
    ]
  };
  const script = document.createElement('script');
  script.type = 'application/ld+json';
  script.text = JSON.stringify(faqSchema);
  document.head.appendChild(script);
</script>
